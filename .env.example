# Environment Variables Configuration

## API Configuration
API_TITLE=Emotion Detection Voice API
API_VERSION=1.0.0
DEBUG=False

## Audio Processing
SAMPLE_RATE=22050
N_MFCC=13
MAX_DURATION=30

## Model Configuration
MODEL_PATH=./models/emotion_model.h5
CONFIDENCE_THRESHOLD=0.7

## Server Configuration
HOST=0.0.0.0
PORT=8000

## Database
DATABASE_URL=sqlite:///./emotion_detection.db
SQLALCHEMY_TRACK_MODIFICATIONS=False

## Authentication
SECRET_KEY=your-secret-key-here
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=24

## Security
CORS_ORIGINS=["http://localhost:3000", "http://localhost:8000"]
ALLOWED_EXTENSIONS=wav,mp3,flac,ogg

## Logging
LOG_LEVEL=INFO
LOG_FILE=./logs/app.log

## Cache
CACHE_TTL=3600
CACHE_MAX_SIZE=1000

## External Services
SENTRY_DSN=
ENABLE_METRICS=True
