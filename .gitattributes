# Auto line-ending conversion
* text=auto

# Python files
*.py text eol=lf
*.pyx text eol=lf

# Shell scripts
*.sh text eol=lf
*.bash text eol=lf

# Windows scripts
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Documents
*.md text eol=lf
*.txt text eol=lf

# Binary files
*.pth binary
*.pkl binary
*.pt binary
*.wav binary
*.mp3 binary
*.ogg binary
